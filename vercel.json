{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "klicenka.weeks.cz" }],
      "destination": "/navody/nfc-prepis-cipu/",
      "permanent": false
    }
  ],
  "crons": [{ "path": "/api/cron/retention", "schedule": "0 3 * * 0" }]
}
