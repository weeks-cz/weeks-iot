# Email transport for /api/notify-account (production: set in Vercel project env)
# Resend (https://resend.com) — current default provider; swap freely.
RESEND_API_KEY=
ACCOUNT_EMAIL_FROM=Weeks IoT <noreply@weeks.cz>
PUBLIC_WAITLIST_TO=info@weeks.cz

# Weeks Hub sync for public classroom waitlist
WEEKS_HUB_API_URL=
WEEKS_HUB_API_KEY=

# Dev override — when "1", new accounts seed with TEST_BALANCE (see Task 11).
# Leave blank in production.
NEXT_PUBLIC_TEST_MODE=

# PINs for camp deployment. If unset, fallback to "123" / "2468" / "321"
# (visible in code AND triggers a red warning banner in the admin panel).
# These values still ship in the JS bundle — env is for rotation, not secrecy.
NEXT_PUBLIC_DAILY_PIN=
NEXT_PUBLIC_LECTURER_PIN=
NEXT_PUBLIC_ADMIN_PASSWORD=

# Supabase (Fáze 1 — required for email auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# AI tutor (/api/chat) — Vercel AI Gateway.
# Na Vercelu funguje i bez klíče přes OIDC; lokálně nastav AI_GATEWAY_API_KEY.
# Bez klíče i OIDC route vrací 503 a UI ukáže "AI tutor zatím není zapnutý".
AI_GATEWAY_API_KEY=
# Volitelně přepiš model (default: anthropic/claude-haiku-4.5).
TUTOR_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Platby a fakturace (část C: premium subscriptions)
# ─────────────────────────────────────────────────────────────────────────────

# Service role klíč projektu UČEBNY (stejný projekt jako NEXT_PUBLIC_SUPABASE_URL).
# POZOR: NE klíč hub projektu (weeks-hub kanban) — v repu se historicky vyskytoval
# SUPABASE_URL mířící na hub; server routes ho záměrně NEčtou.
# Používá /api/payment/create, /api/payment/callback a /api/cron/retention.
SUPABASE_SERVICE_ROLE_KEY=

# Comgate (https://www.comgate.cz) — platební brána
# Bez COMGATE_MERCHANT a COMGATE_SECRET: /api/payment/create vrací 503,
# UI zobrazí "Platby zatím nejsou zapnuté"
COMGATE_MERCHANT=
COMGATE_SECRET=
# Testovací režim (default: true). V produkci nastav na "false" po testování.
COMGATE_TEST=true
# Metody platby dostupné na bráně (default: ALL)
COMGATE_METHOD=ALL

# Veřejná URL aplikace (pro return URL z Comgate)
NEXT_PUBLIC_SITE_URL=https://iot.weeks.cz

# Fakturoid (https://www.fakturoid.cz) — vydávání daňových dokladů
# Bez těchto proměnných se faktury nevystavují (ale platba se uskuteční)
FAKTUROID_SLUG=
FAKTUROID_CLIENT_ID=
FAKTUROID_CLIENT_SECRET=
# Volitelně: User-Agent pro Fakturoid API (default: "Weeks IoT (admin@weeks.cz)")
FAKTUROID_USER_AGENT=

# Resend (https://resend.com) — transakční e-maily
# RESEND_API_KEY je již vyšší (pro /api/notify-account)
# RESEND_FROM slouží pro e-maily z plateb (default: "Weeks <info@weeks.cz>")
# Závisí na doméně weeks.cz, která je v Resend ověřena (eu-west-1)
RESEND_FROM=Weeks <info@weeks.cz>

# Cron auth (retention cleanup, Vercel cron middleware)
# /api/cron/retention běží denně ve 3:00 UTC — maže learning_events starší 365 dní
# a zároveň slouží jako keep-alive proti auto-pauze Supabase free tieru.
# Vyžaduje tento secret v Authorization headeru.
CRON_SECRET=
